{
  "name": "academiya",
  "version": "0.1.0",
  "private": true,
  "description": "Academiya academy management platform monorepo.",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev:web": "pnpm --filter @academiya/web dev",
    "dev:mobile": "pnpm --filter @academiya/mobile start",
    "build:web": "pnpm --filter @academiya/web build",
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20"
  }
}
